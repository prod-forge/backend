{
  "name": "prod-forge-todolist-backend",
  "version": "0.1.6",
  "description": "Real-world backend architecture patterns, production mistakes and lessons learned building scalable systems.",
  "repository": {
    "type": "git",
    "url": "https://github.com/prod-forge/backend.git"
  },
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com>",
  "scripts": {
    "build": "nest build",
    "db:generate": "prisma generate",
    "db:init": "prisma migrate deploy && prisma generate",
    "db:migrate": "prisma migrate dev --name",
    "db:migration:apply": "npm run db:wait && npm run db:migration:deploy",
    "db:migration:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:wait": "tsx ./database-manager/wait-for-db.ts",
    "format": "npm run format:prettier && npm run format:code",
    "format:code": "eslint . --fix",
    "format:prettier": "prettier --write \"src/**/*.{ts,json}\"",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:commit": "commitlint -e",
    "lint:ts": "tsc --noEmit",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "release": "tsx release/before-release.ts && npx release-it",
    "start": "cross-env NODE_ENV=development nest start",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main",
    "test": "cross-env NODE_ENV=test jest",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --config test/setup/jest-e2e.json --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@scalar/nestjs-api-reference": "^1.1.0",
    "@sentry/node": "^10.42.0",
    "@sentry/profiling-node": "^10.42.0",
    "@sentry/tracing": "^7.120.4",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express-http-context": "^2.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.15",
    "@release-it/conventional-changelog": "^10.0.5",
    "@testcontainers/postgresql": "^11.12.0",
    "@testcontainers/redis": "^11.12.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.11.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-package-json": "^0.89.3",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-regexp": "^3.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "inquirer": "^13.3.0",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
